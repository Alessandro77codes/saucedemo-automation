{
  "name": "saucedemo-automation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean:reports": "rimraf cypress/reports",
    "cy:run": "npx cypress run --spec 'cypress/e2e/formulario.cy.js'",
    "report:merge": "npx mochawesome-merge cypress/reports/mochawesome-report/*.json > cypress/reports/report.json",
    "report:generate": "npx marge cypress/reports/report.json -o cypress/reports/mochawesome-report --inline",
    "executar:tudo": "npm run clean:reports && npm run cy:run || npm run report:merge && npm run report:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "cypress": "^15.16.0",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^6.1.3"
  }
}
